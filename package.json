{
	"name": "discordjsx",
	"version": "0.1.0",
	"description": "React for discord.js",
	"author": "Powerbox1000",
	"contributors": [
		"deniz.blue <deniz@deniz.blue>"
	],
	"type": "module",
	"files": [
		"/dist"
	],
	"exports": {
		".": "./src/index.ts",
		"./internals": "./src/internals.ts"
	},
	"scripts": {
		"prebuild": "node -p \"'export const VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
		"build": "tsc",
		"prepare": "npm run build"
	},
	"devDependencies": {
		"@types/mime-types": "^2.1.4",
		"@types/react": "npm:pure-react-types@^0.1.4",
		"@types/react-reconciler": "^0.32.3",
		"@types/uuid": "^10.0.0",
		"dotenv": "^16.6.1",
		"typescript": "5.8.3"
	},
	"peerDependencies": {
		"discord.js": "^14.23.2",
		"react": "^19.1.0"
	},
	"dependencies": {
		"mime-types": "^3.0.2",
		"nanoevents": "^9.1.0",
		"react-reconciler": "^0.32.0",
		"uuid": "^11.1.0"
	},
	"keywords": [
		"react",
		"jsx",
		"discord.js",
		"components",
		"renderer"
	],
	"license": "GPL-3.0-only",
	"bugs": {
		"url": "https://github.com/SimplyPlural-Discord-Integration/discordjsx/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SimplyPlural-Discord-Integration/discordjsx.git"
	},
	"engines": {
		"node": ">=25"
	}
}
